@model Post
@{
    ViewData["Title"] = Model.Title;
}

<div class="mb-3">
    <a class="btn btn-secondary btn-sm" asp-action="Index">&larr; Back to posts</a>
</div>

<div class="card mb-4">
    <div class="card-header">Post Info</div>
    <div class="card-body">
        <h2 class="card-title h4">@Model.Title</h2>
        <p class="card-text" style="white-space: pre-wrap;">@Model.Description</p>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">Post Creator Info</div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@(Model.User?.Name ?? "not found")</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@(Model.User?.Email ?? "not found")</dd>

            <dt class="col-sm-3">Created At</dt>
            <dd class="col-sm-9">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
        </dl>
    </div>
</div>

@using System.Security.Claims
@{
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

@if (User.Identity?.IsAuthenticated == true && Model.UserId?.ToString() == currentUserId)
{
    <div class="mt-3 d-flex gap-2">
        <a class="btn btn-warning" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline"
              onsubmit="return confirm('Delete this post?');">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger">Delete Post</button>
        </form>
    </div>
}
