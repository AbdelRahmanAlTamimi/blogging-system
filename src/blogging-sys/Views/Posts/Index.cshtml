@model PostListViewModel
@using System.Security.Claims
@{
    ViewData["Title"] = "All Posts";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">All Posts</h1>
    <a class="btn btn-primary" asp-action="Create">Create Post</a>
</div>

<form asp-action="Index" method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <input type="text" name="search" value="@Model.Search" class="form-control"
               placeholder="Search by title..." />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary">Search</button>
    </div>
    @if (!string.IsNullOrWhiteSpace(Model.Search))
    {
        <div class="col-auto">
            <a class="btn btn-outline-secondary" asp-action="Index">Clear</a>
        </div>
    }
</form>

@if (!Model.Posts.Any())
{
    <div class="alert alert-info">No posts found.</div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Posted By</th>
                <th>Created At</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var post in Model.Posts)
            {
                <tr>
                    <td>@post.Id</td>
                    <td>@post.Title</td>
                    <td>@(post.User?.Name ?? "not found")</td>
                    <td>@post.CreatedAt.ToString("yyyy-MM-dd")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-info" asp-action="Details" asp-route-id="@post.Id">View</a>
                        @if (User.Identity?.IsAuthenticated == true && post.UserId?.ToString() == currentUserId)
                        {
                            <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@post.Id">Edit</a>
                            <form asp-action="Delete" asp-route-id="@post.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete this post?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Post pagination">
            <ul class="pagination">
                <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-search="@Model.Search"
                       asp-route-page="@(Model.Page - 1)">Previous</a>
                </li>
                @for (var p = 1; p <= Model.TotalPages; p++)
                {
                    <li class="page-item @(p == Model.Page ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-search="@Model.Search"
                           asp-route-page="@p">@p</a>
                    </li>
                }
                <li class="page-item @(Model.HasNext ? "" : "disabled")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-search="@Model.Search"
                       asp-route-page="@(Model.Page + 1)">Next</a>
                </li>
            </ul>
        </nav>
    }

    <p class="text-muted small">@Model.TotalCount post(s) total.</p>
}
