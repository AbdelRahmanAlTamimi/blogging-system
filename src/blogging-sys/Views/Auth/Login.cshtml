@model LoginViewModel
@{
    ViewData["Title"] = "Log In";
}

<div class="row justify-content-center my-5">
    <div class="col-md-5">
        <div class="card shadow border-0 rounded-3">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <h1 class="h3 fw-bold mt-2">Welcome Back</h1>
                    <p class="text-muted">Sign in to your account</p>
                </div>

                <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Email" class="form-control rounded-3" placeholder="name@example.com" required autocomplete="email" />
                        <label asp-for="Email">Email address</label>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Password" type="password" class="form-control rounded-3" placeholder="Password" required autocomplete="current-password" />
                        <label asp-for="Password">Password</label>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label text-muted">
                            Remember my login
                        </label>
                    </div>

                    <button class="w-100 btn btn-lg btn-primary rounded-3 py-2" type="submit">Sign In</button>
                </form>

                <hr class="my-4 text-muted">

                <div class="text-center">
                    <p class="text-muted mb-0">Don't have an account? <a asp-action="Register" class="text-decoration-none">Sign up now</a></p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
